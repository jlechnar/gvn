alias.alias-svn-stash-fetch-tag-rebase-dcommit-svnnotessetunset-unstash=!bash -c 'cd -- "${GIT_PREFIX:-.}";           set -e;           changes=`git status --short | grep -v "??"`;           if [[ "$changes" != "" ]]; then             echo "Detected local changes. Auto stashing them for later restore.";             git stash -m "Automatic stashed local changes before git svn update";           fi;           git svn fetch;           datetime=`date '+%Y%m%d_%H%M%S'`;           git tag -a auto_tag_svn_rebase_$datetime -m "Auto added rebase tag $datetime";           git svn rebase;           git svn dcommit;           git aliassvnnotessetunset;           if [[ "$changes" != "" ]]; then             git stash pop;           fi;' --
alias.aliasdiffall=diff '--word-diff-regex=[^[:space:]]' --word-diff=color -U0 --ignore-all-space --ignore-blank-lines --ignore-space-change
alias.alias-worktree-merge=!bash -c 'cd -- "${GIT_PREFIX:-.}";           to_merge=$1;           datetime=`date '+%Y%m%d_%H%M%S'`;           to_merge_into=`git rev-parse --abbrev-ref HEAD`;           tag_name="auto_tag_worktree_merge_${to_merge}_into_${to_merge_into}_${datetime}";           changes=`git status --short | grep -v "??"`;           if [[ "$changes" != "" ]]; then             echo "Detected local changes. Auto stashing them for later restore.";             git stash -m "Automatic stashed local changes before git merge ($tag_name)";           fi;           git tag -a $tag_name -m "Auto added tag for worktree merge $to_merge into $to_mergo_into at $datetime";           git merge --ff-only $to_merge;           if [[ "$changes" != "" ]]; then             git stash pop;           fi;' --
alias.alias-worktree-rebase=!bash -c 'cd -- "${GIT_PREFIX:-.}";           to_rebase_onto=$1;           datetime=`date '+%Y%m%d_%H%M%S'`;           to_rebase=`git rev-parse --abbrev-ref HEAD`;           tag_name="auto_tag_worktree_rebase_${to_rebase}_onto_${to_rebase_onto}_${datetime}" ;           changes=`git status --short | grep -v "??"`;           if [[ "$changes" != "" ]]; then             echo "Detected local changes. Auto stashing them for later restore.";             git stash -m "Automatic stashed local changes before git rebase ($tag_name)";           fi;           git tag -a $tag_name -m "Auto added tag for worktree rebase from $to_rebase onto $to_rebase_onto at $datetime";           git rebase $to_rebase_onto;           if [[ "$changes" != "" ]]; then             git stash pop;           fi;' --

