alias.aliassvnnotessetall=!bash -c 'cd -- "${GIT_PREFIX:-.}"; (git log --pretty=format:'%H'; echo "") | while read hash; do svn_rev=$(git svn find-rev $hash); if [[ "$svn_rev" == "" ]]; then svn_rev="---"; fi; git notes add -m "r$svn_rev" $hash -f; done;' --
alias.aliassvnnotessetunset=!bash -c 'cd -- "${GIT_PREFIX:-.}";           (git log --pretty=format:'%H'; echo "") |           while read hash;           do             note=`git notes show "$hash" > /dev/null 2>&1`;              if [[ "$?" != "0" ]]; then                svn_rev=`git svn find-rev $hash`;               if [[ "$svn_rev" == "" ]]; then                 svn_rev="---";               fi;               echo "$hash -> $svn_rev";               git notes add -m "r$svn_rev" $hash;             fi;           done;' --
alias.aliaslogsvn=!bash -c 'cd -- "${GIT_PREFIX:-.}"; (echo "@
"; git log --oneline --graph --decorate "--date=format-local:%Y-%m-%d %H:%M:%S" --pretty=tformat:"%C(yellow)%h%C(reset) - %C(bold blue)#%N#%C(reset), %C(blue)%an%C(reset), %C(green)%ad%C(reset) :  %s %C(auto)%d%C(reset)@" --show-notes) | egrep -v "Notes added by .+git notes add.+" | perl -pe "\$/="@\n"; s/#(.*)\n.*#/\$1/g; s/#(.*)#/r???/g; s,@\n,\n,g;" | egrep -v "^$"' --
alias.aliaslogsvnall=!bash -c 'cd -- "${GIT_PREFIX:-.}"; (echo "@
"; git log --oneline --graph --all --decorate "--date=format-local:%Y-%m-%d %H:%M:%S" --pretty=tformat:"%C(yellow)%h%C(reset) - %C(bold blue)#%N#%C(reset), %C(blue)%an%C(reset), %C(green)%ad%C(reset) :  %s %C(auto)%d%C(reset)@" --show-notes | egrep -v "Notes added by .+git notes add.+") | perl -pe "BEGIN { \$/=\"@\n\"; } s/#(.*)\n.*#/\$1/g; s/#(.*)#/r???/g; s,@\n,\n,g;" | egrep -v "^$"' --
