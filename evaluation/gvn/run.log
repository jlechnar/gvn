        alias-worktree-rebase="!bash -c 'cd -- \"${GIT_PREFIX:-.}\"; \
          to_rebase_onto=$1; \
          datetime=`date '+%Y%m%d_%H%M%S'`; \
          to_rebase=`git rev-parse --abbrev-ref HEAD`; \
          tag_name=\"auto_tag_worktree_rebase_${to_rebase}_onto_${to_rebase_onto}_${datetime}\" ; \
          changes=`git status --short | grep -v \"??\"`; \
          if [[ \"$changes\" != \"\" ]]; then \
            echo \"Detected local changes. Auto stashing them for later restore.\"; \
            git stash -m \"Automatic stashed local changes before git rebase ($tag_name)\"; \
          fi; \
          git tag -a $tag_name -m \"Auto added tag for worktree rebase from $to_rebase onto $to_rebase_onto at $datetime\"; \
          git rebase $to_rebase_onto; \
          if [[ \"$changes\" != \"\" ]]; then \
            git stash pop; \
          fi;' --"

